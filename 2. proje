                    <h4 class="text-sm font-bold text-white leading-snug mb-2">${match.title}</h4>
                    <div class="flex items-center gap-2">
                        <span class="text-3xl font-black tracking-tight text-white">${skoru}</span>
                        <span class="text-[11px] font-bold px-2 py-0.5 rounded border ${sonucCss[match.stats.sonuc]}">${sonucEtiket[match.stats.sonuc]}</span>
                    </div>
                    ${gollerHtml(match.goller)}
                </div>`;
        });
    }

    document.getElementById("yearSelect").addEventListener("change", (e) => renderContent(e.target.value));
    renderContent("all");
    </script>
</body>
</html>
