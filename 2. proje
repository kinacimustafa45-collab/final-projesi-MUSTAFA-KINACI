    function generateAnalysis(year, filteredMatches) {
        if (year === "all") {
            return `<strong>Genel Veri Analizi:</strong> Sistemde şu an 2012-2026 yılları arasını kapsayan toplam ${filteredMatches.length} kritik maç (Büyük Derbiler & Avrupa Kupaları) listelenmiştir. Dönemsel taktik ve başarı analitiğini görmek için lütfen listeden bir sezon seçin.`;
        }
        let totalGoals = 0, totalConceded = 0, wins = 0;
        filteredMatches.forEach(m => {
            totalGoals += m.stats.gsGol;
            totalConceded += m.stats.rakipGol;
            if (m.stats.sonuc === "G") wins++;
        });
        return `
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4 text-center">
                <div class="bg-gray-900 p-3 rounded-lg border border-gray-700">
                    <span class="text-xs text-gray-400 block">Maç Başına Gol Ortalaması</span>
                    <span class="text-lg font-bold text-[#FDB913]">${(totalGoals/filteredMatches.length).toFixed(1)}</span>
                </div>
                <div class="bg-gray-900 p-3 rounded-lg border border-gray-700">
                    <span class="text-xs text-gray-400 block">Kritik Maç Kazanma Oranı</span>
                    <span class="text-lg font-bold text-green-400">%${((wins/filteredMatches.length)*100).toFixed(0)}</span>
                </div>
                <div class="bg-gray-900 p-3 rounded-lg border border-gray-700">
                    <span class="text-xs text-gray-400 block">Toplam Atılan Gol</span>
                    <span class="text-lg font-bold text-red-400">${totalGoals} Gol</span>
                </div>
            </div>
            <p class="text-sm md:text-base"><strong>[Dönemsel Taktik Karakteristiği]:</strong><br>${tacticalMap[year] || "Sezon taktik analizi."}</p>
        `;
    }

    function gollerHtml(goller) {
        if (!goller || goller.length === 0) {
            return `<p class="text-xs text-gray-600 italic mt-3 border-t border-gray-700 pt-2">Gol yok (0-0)</p>`;
        }
        const tipIkonu = { "gol": "⚽", "penalti": "🎯", "kendi kalesi": "🔴" };
        const gs = goller.filter(g => g.taraf === "gs");
        const rakip = goller.filter(g => g.taraf === "rakip");
        const satir = (g) => `
            <div class="flex items-center gap-1 text-xs py-0.5">
                <span class="text-gray-500 w-6 text-right shrink-0 font-mono">${g.dk}'</span>
                <span class="shrink-0">${tipIkonu[g.tip] || "⚽"}</span>
                <span class="${g.taraf === 'gs' ? 'text-[#FDB913] font-medium' : 'text-gray-300'} truncate">${g.oyuncu}</span>
                ${g.tip === 'penalti' ? '<span class="text-gray-500 text-[10px] shrink-0">(P)</span>' : ''}
                ${g.tip === 'kendi kalesi' ? '<span class="text-red-500 text-[10px] shrink-0">(KK)</span>' : ''}
            </div>`;
        return `
            <div class="grid grid-cols-2 gap-2 mt-3 border-t border-gray-700 pt-3">
                <div>
                    <p class="text-[10px] font-bold text-[#FDB913] uppercase tracking-wide mb-1">🟡 Galatasaray</p>
                    ${gs.length ? gs.map(satir).join("") : '<p class="text-xs text-gray-600">—</p>'}
                </div>
                <div>
                    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-wide mb-1">⚪ Rakip</p>
                    ${rakip.length ? rakip.map(satir).join("") : '<p class="text-xs text-gray-600">—</p>'}
                </div>
            </div>`;
    }

    function renderContent(selectedYear) {
        const grid = document.getElementById("matchGrid");
        const filtered = selectedYear === "all" ? matchData : matchData.filter(m => m.year === selectedYear);

        document.getElementById("sectionTitle").innerText = selectedYear === "all"
            ? "Tüm Dönemlerin Kritik Maçları"
            : `${selectedYear}-${parseInt(selectedYear)+1} Sezonu`;
        document.getElementById("matchCount").innerText = `${filtered.length} Maç Listelendi`;
        document.getElementById("statsOutput").innerHTML = generateAnalysis(selectedYear, filtered);

        grid.innerHTML = "";
        if (filtered.length === 0) {
            grid.innerHTML = `<p class="text-gray-500 col-span-full text-center py-8">Bu döneme ait maç kaydı bulunamadı.</p>`;
            return;
        }

        const sonucCss = { G: "bg-green-900 text-green-300 border-green-700", B: "bg-yellow-900 text-yellow-300 border-yellow-700", M: "bg-red-900 text-red-300 border-red-700" };
        const sonucEtiket = { G: "GALİBİYET", B: "BERABERLİK", M: "MAĞLUBIYET" };

        filtered.forEach(match => {
            const skoru = match.title.match(/\d+ - \d+/)?.[0] ?? "";
            grid.innerHTML += `
                <div class="bg-gray-800 rounded-xl overflow-hidden shadow-lg border border-gray-700 p-4 flex flex-col hover:border-[#FDB913] transition-all duration-300">
                    <div class="flex justify-between items-center mb-2">
                        <span class="bg-[#A32638] text-[#FDB913] text-xs font-bold px-2 py-1 rounded-md">${match.year}-${parseInt(match.year)+1}</span>
